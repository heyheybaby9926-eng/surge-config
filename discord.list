IP-CIDR,141.101.0.0/16,no-resolve
# Discord 专用的 STUN 端口（UDP 3478）
DEST-PORT,3478,UDP

REJECT,UDP,443

DOMAIN,stun.l.google.com
DOMAIN-KEYWORD,stun
DOMAIN-KEYWORD,turn
